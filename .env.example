# Supabase – copy this file to .env and fill in your real values.
# Do NOT commit .env to git (it's already in .gitignore).

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# true  = force Supabase-backed tasks/sessions/records + RPCs.
# false = force localStorage mode.
# unset = auto-enable Supabase when URL+anon key exist (recommended for production safety).
VITE_USE_SUPABASE=true
