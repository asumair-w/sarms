# Supabase – copy this file to .env and fill in your real values.
# Do NOT commit .env to git (it's already in .gitignore).

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# true = Supabase-backed tasks/sessions/records + RPCs; inventory mirror follows this flag.
# false = localStorage for those; equipment / equipment_tickets / resolved_tickets mirror whenever URL+anon key exist.
VITE_USE_SUPABASE=true
